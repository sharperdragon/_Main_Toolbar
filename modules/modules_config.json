{
  "global_config": {
    "log_dir": "~/Desktop/anki_logs/Main_toolbar",
    "ts_format": "%H-%M_%m-%d"
  },
  "missing_media_config": {
    "tag_filter_enabled": true,
    "tag_name": "missing-media",
    "media_extensions": [".png", ".jpg", ".jpeg", ".svg", ".gif", ".mp3", ".mp4"],
    "output_dir": "~/Desktop/Missing Media files",
    "backup_dir": "~/ANki/Missing Media/backup"
  },
  "unused_media_config": {
    "default_output_dir": "~/Desktop",
    "filename_prefix": "unused_anki_media",
    "chunk_size": 30
  },
  "img_dupes_config": {
    "fields": ["Text", "Extra", "Extra2", "Extra3", "Extra4", "Extra5", "Button", "Display"],
    "backup_threshold": 45,
    "backup_path": "~/ANki/Missing Media/backups/dupe_img_nids.txt"
  },
  "log_cleanup_config": {
    "logs_root": "~/Desktop/anki_logs/Main_toolbar",
    "allowed_suffixes": [".log", ".txt", ".md"],
    "safe_root_marker": "anki_logs",
    "keep_runs": 2
  },
  "batch_FR_config": {
    "rules_path": "batch_FR/rules",
    "remove_rules_suffix": "_remove_rules.txt",
    "field_remove_rules_name": "field_remove_rules.txt",
    "fields_all": [
      "Text",
      "Extra",
      "Extra2",
      "Extra3",
      "Extra4",
      "Extra5",
      "Extra6",
      "Extra7",
      "Front",
      "Back",
      "Display",
      "Button"
    ],
    "log_mode": "diff",
    "include_unchanged": false,
    "Defaults": {
      "exclude_query": "",
      "regex": true,
      "flags": "m",
      "loop": false,
      "fields": ["ALL"],
      "delete_chars": { "max_chars": 0, "count_spaces": true }
    },
    "remove_config": {
      "regex": true,
      "flags": "ms",
      "loop": true,
      "delete_chars": { "max_chars": -1, "count_spaces": false }
    },
    "max_loops": 10,
    "order_preference": {
      "testing_rules.json": 1,
      "remove_rules.txt": 2,
      "base_rules.json": 3
    },
    "batch_fr_debug": {
      "enabled": true,
      "max_examples_per_rule": 3,
      "max_rules": 200
    }
  },
  "tag_renaming": {
    "dry_run_default": true,
    "allow_regex": true,
    "pairs_csv": "tag_renaming/tag_renaming.csv",
    "pairs_json": "tag_renaming/new_tag_rules.json",
    "batch_commit_size": 1000,
    "max_expansions_per_rule": 500,
    "debug_regex": true,
    "regex_debug_examples": 25
  }
}
